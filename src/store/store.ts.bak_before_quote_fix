      type: RECORDING_FILE_TYPE,
    } as never,
  );
  formData.append('language', language);
  formData.append('mime_type', RECORDING_FILE_TYPE);

  const payload = await requestBackend<{ text?: string }>('/api/asr', {
    method: 'POST',
    body: formData,
