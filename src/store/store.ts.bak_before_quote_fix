function mergeUserTranscript(
  transcript: TranscriptLine[],
  text: string,
  language: PracticeLanguage,
  recordingStartedAt: string | null,
) {
  const trimmedText = text.trim();
  if (!trimmedText) {
    return transcript;
  }

  const nextTranscript = [...transcript];
  const lastUserIndex = [...nextTranscript].reverse().findIndex((line) => line.speaker === 'user');

  if (lastUserIndex === -1) {
    nextTranscript.push({
      id: `line-${Date.now()}`,
      text: trimmedText,
      timestampMs: buildTimestampMs(recordingStartedAt),
      confidence: 0.98,
      speaker: 'user',
    });
    return nextTranscript;
  }

  const actualLastIndex = nextTranscript.length - 1 - lastUserIndex;
  const lastLine = nextTranscript[actualLastIndex];
  const lastText = lastLine?.text.trim() ?? '';

  if (!lastText) {
    nextTranscript[actualLastIndex] = {
      ...lastLine,
      text: trimmedText,
      timestampMs: buildTimestampMs(recordingStartedAt),
    };
    return nextTranscript;
  }

  if (normalizeComparisonText(lastText) === normalizeComparisonText(trimmedText)) {
    return nextTranscript;
  }

  const suffix = extractSuffixAfterLoosePrefix(trimmedText, lastText);
  if (suffix !== null) {
    if (!suffix || isWeakStandalonePartial(suffix, language)) {
      return nextTranscript;
    }

    nextTranscript[actualLastIndex] = {
      ...lastLine,
      text: language === 'zh-CN' ? `${lastText}${suffix}` : `${lastText} ${suffix}`.trim(),
      timestampMs: buildTimestampMs(recordingStartedAt),
    };
    return nextTranscript;
  }

  if (lastText.startsWith(trimmedText) || lastText.endsWith(trimmedText)) {
    return nextTranscript;
  }

  if (isShortPartial(trimmedText, language) || isWeakStandalonePartial(trimmedText, language)) {
    nextTranscript[actualLastIndex] = {
      ...lastLine,
      text: language === 'zh-CN' ? `${lastText}${trimmedText}` : `${lastText} ${trimmedText}`.trim(),
      timestampMs: buildTimestampMs(recordingStartedAt),
    };
    return nextTranscript;
  }

  nextTranscript.push({
    id: `line-${Date.now()}`,
    text: trimmedText,
    timestampMs: buildTimestampMs(recordingStartedAt),
    confidence: 0.98,
    speaker: 'user',
  });
  return nextTranscript;
}

