function getQAAutoAdvanceDelay(text: string) {
  const compactLength = text.replace(/\s+/g, '').length;
  const hasStrongEnding = /[銆傦紒锛??]$/.test(text.trim());

  if (compactLength >= 32 && hasStrongEnding) {
    return 900;
  }

  if (compactLength >= 18) {
    return 1200;
  }

  return QA_AUTO_ADVANCE_MS;
}

function armVoiceContentRefreshTimer() {
  const state = usePracticeStore.getState();

  if (state.voiceContentFlushTimeoutId) {
    clearTimeout(state.voiceContentFlushTimeoutId);
  }

  if (state.status !== 'recording' || state.qaEnabled) {
    return;
  }

  const timeoutId = setTimeout(async () => {
    const latestState = usePracticeStore.getState();

    usePracticeStore.setState({
      voiceContentFlushTimeoutId: null,
    });

    if (latestState.status !== 'recording' || latestState.qaEnabled) {
      return;
    }

    const currentText = getRecentUserTranscript(latestState.transcript, 3);
    const latestSegment = latestState.recentVoiceSegments[latestState.recentVoiceSegments.length - 1] ?? null;

    if (!currentText || !latestSegment) {
      return;
    }

    await latestState.fetchAICoachFeedback(currentText, {
      scope: 'voice_content',
      audioSegmentUri: latestSegment.uri,
      audioTranscript: latestSegment.transcript,
    });
  }, VOICE_CONTENT_SILENCE_WINDOW_MS);

  usePracticeStore.setState({
    voiceContentFlushTimeoutId: timeoutId,
  });
}

