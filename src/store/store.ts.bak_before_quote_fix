          usePracticeStore.setState({
            status: 'finished',
            currentReport: settledState.pendingReport,
            pendingReport: null,
            analysisProgress: 100,
            analysisIntervalId: null,
            lastCoachScopeSignatures: {
              voice_content: null,
              body_visual: null,
            },
            liveCoachInsight: settledState.pendingReport.headline,
          });
        }, 200);
        return;
