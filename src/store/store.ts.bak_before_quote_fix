}

function countUserTranscriptLines(lines: TranscriptLine[]) {
  return lines.filter((line) => line.speaker === 'user').length;
}

function countPattern(text: string, pattern: RegExp) {
  return (text.match(pattern) ?? []).length;
}

function getRecentUserTranscript(lines: TranscriptLine[], maxLines = 3) {
  return lines
    .filter((line) => line.speaker === 'user')
    .slice(-maxLines)
