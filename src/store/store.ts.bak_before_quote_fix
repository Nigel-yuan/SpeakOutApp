}

function buildSpeechContextFromTranscript(lines: TranscriptLine[], language: PracticeLanguage) {
  const recentText = getRecentUserTranscript(lines, 2);
  if (!recentText) {
    return null;
  }

  const compact = recentText.replace(/\s+/g, '');
  const fillerCount =
    language === 'zh-CN'
      ? countPattern(recentText, /(鐒跺悗|灏辨槸|閭ｄ釜|鍏跺疄|鎴戣寰梶鍡瘄鍛?/g)
      : countPattern(recentText, /\b(um|uh|well|like|you know)\b/gi);
  const restartCount =
    language === 'zh-CN'
      ? countPattern(recentText, /(鎴戞垜|鐒跺悗鐒跺悗|灏辨槸灏辨槸)/g)
      : countPattern(recentText, /\b(\w+)\s+\1\b/gi);

  return {
    excerpt: recentText.slice(-120),
    charCount: compact.length,
    fillerCount,
    restartCount,
    rhythmHint:
      fillerCount >= 3 || restartCount >= 2
        ? 'pace_unstable'
        : compact.length >= 36
          ? 'pace_building'
          : 'warming_up',
  };
}

