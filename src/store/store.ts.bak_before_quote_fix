function armQAAutoAdvanceTimer(latestText = '') {
  const state = usePracticeStore.getState();

  if (!state.qaEnabled || state.qaPhase !== 'user_answering') {
    return;
  }

  if (state.qaAutoAdvanceTimeoutId) {
    clearTimeout(state.qaAutoAdvanceTimeoutId);
  }

  const timeoutId = setTimeout(() => {
    const latestState = usePracticeStore.getState();
    if (!latestState.qaEnabled || latestState.qaPhase !== 'user_answering') {
      return;
    }

    void latestState.continueCoachQA();
  }, getQAAutoAdvanceDelay(latestText));

  usePracticeStore.setState({
    qaAutoAdvanceTimeoutId: timeoutId,
  });
}

