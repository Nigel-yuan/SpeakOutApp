              text,
              timestampMs: buildTimestampMs(state.recordingStartedAt),
              confidence: 0.98,
              speaker,
            },
          ],
        };
      }

      const nextTranscript = mergeUserTranscript(state.transcript, text, state.activeLanguage, state.recordingStartedAt);
      const speechRuleUpdate = buildSpeechRuleCoachUpdate(nextTranscript, state.activeLanguage, state.coachPanel);

      if (!speechRuleUpdate.shouldEmit) {
        return {
          transcript: nextTranscript,
        };
      }

      const nextVoiceSignature = buildCoachScopeSignature(speechRuleUpdate.coachPanel, 'voice_content');
      const sameVoiceSignature = state.lastCoachScopeSignatures.voice_content === nextVoiceSignature;

      return {
        transcript: nextTranscript,
        coachPanel: sameVoiceSignature ? state.coachPanel : speechRuleUpdate.coachPanel,
        lastCoachScopeSignatures: sameVoiceSignature
          ? state.lastCoachScopeSignatures
          : {
              ...state.lastCoachScopeSignatures,
              voice_content: nextVoiceSignature,
            },
        liveCoachInsight: state.qaEnabled || sameVoiceSignature ? state.liveCoachInsight : speechRuleUpdate.insight,
        liveCoach:
          state.qaEnabled || sameVoiceSignature
            ? state.liveCoach
            : {
                id: `coach-rule-${Date.now()}`,
                tone: 'analytical',
                title: 'Omni Live Coach',
                body: speechRuleUpdate.insight,
                generatedAt: new Date().toISOString(),
                source: 'system',
              },
      };
    });

    if (speaker === 'user') {
      armQAAutoAdvanceTimer(text);
    }
