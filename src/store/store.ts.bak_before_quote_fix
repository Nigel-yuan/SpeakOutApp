  fetchAICoachFeedback: async (currentText, options) => {
    const scope = options?.scope ?? 'voice_content';

    if (scope === 'voice_content' && !currentText.trim() && !options?.audioSegmentUri) {
      return;
    }

    if (scope === 'body_visual' && !options?.frameBase64) {
      return;
    }

    try {
      const state = usePracticeStore.getState();
      const scene = getCurrentScene(state);
      const payload =
        scope === 'voice_content'
          ? await requestVoiceCoachFeedback({
              currentText,
              activeLanguage: state.activeLanguage,
              sceneTitle: scene.title,
              sceneGoal: scene.goal,
              focusKeywords: scene.focusKeywords,
              audioSegmentUri: options?.audioSegmentUri ?? null,
              audioTranscript: options?.audioTranscript ?? null,
            })
          : await requestBackend<{
              insight?: string;
              shouldEmit?: boolean;
              coachPanel?: CoachPanelState;
            }>('/api/coach', {
              method: 'POST',
              headers: {
                'Content-Type': 'application/json',
              },
              body: JSON.stringify({
                text: currentText,
                language: state.activeLanguage,
                sceneTitle: scene.title,
                sceneGoal: scene.goal,
                focusKeywords: scene.focusKeywords,
                scope,
                frameBase64: options?.frameBase64 ?? null,
                speechContext:
                  scope === 'body_visual'
                    ? buildSpeechContextFromTranscript(state.transcript, state.activeLanguage)
                    : null,
              }),
            });

      if (payload.shouldEmit === false) {
        return;
      }

      const insight = payload.insight?.trim();
      const coachPanel = mergeCoachPanelByScope(
        state.coachPanel,
        payload.coachPanel ?? buildFallbackCoachPanel(currentText, Boolean(options?.frameBase64)),
        scope,
      );
      const nextSignature = buildCoachScopeSignature(coachPanel, scope);

      if (state.lastCoachScopeSignatures[scope] === nextSignature) {
        return;
      }

      if (!insight) {
        return;
      }

      set({
        coachPanel,
        lastCoachScopeSignatures: {
          ...state.lastCoachScopeSignatures,
          [scope]: nextSignature,
        },
        liveCoachInsight: insight,
        liveCoach: {
          id: `coach-${Date.now()}`,
          tone: 'analytical',
          title: 'Omni Live Coach',
          body: insight,
          generatedAt: new Date().toISOString(),
          source: 'ai',
        },
      });
    } catch (error) {
      console.warn('fetchAICoachFeedback failed', error);
      set((state) => ({
        coachPanel: state.coachPanel,
        liveCoachInsight: 'Omni ????????????????????????????',
        liveCoach: {
          ...state.liveCoach,
          body: 'Omni ????????????????????????????',
        },
      }));
    }
  },
