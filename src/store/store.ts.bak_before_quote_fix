      status: 'analyzing',
      activeRecording: null,
      transcriptionIntervalId: null,
      analysisIntervalId: progressIntervalId,
      recentVoiceSegments: [],
      voiceContentFlushTimeoutId: null,
      recordingStartedAt: null,
